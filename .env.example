# ============================================================
# NexusAI OS - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- App ---
NODE_ENV=development
PORT=3000

# --- Database (MySQL) ---
# For local development:
DATABASE_URL=mysql://root:rootpassword@localhost:3306/nexusai
# For Railway/MySQL (production):
# DATABASE_URL=mysql://user:password@host.railway.app:3306/railway

# --- Redis (Optional - for caching & sessions) ---
REDIS_URL=redis://localhost:6379

# --- Authentication (OAuth 2.0) ---
VITE_KIMI_AUTH_URL=https://your-auth-provider.com
VITE_APP_ID=your_app_id
VITE_AGENT_ID=your_agent_id
KIMI_APP_SECRET=your_app_secret

# --- JWT ---
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=8h

# --- Frontend ---
VITE_APP_ENV=development
VITE_API_BASE_URL=http://localhost:3000
VITE_WEBSOCKET_URL=ws://localhost:3000

# --- WhatsApp Business API ---
WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# --- Shipping APIs ---
BOSTA_API_KEY=your_bosta_api_key
ARAMEX_API_KEY=your_aramex_api_key
MYLERZ_API_KEY=your_mylerz_api_key
VHUB_API_KEY=your_vhub_api_key

# --- Payment Gateway ---
PAYMOB_API_KEY=your_paymob_api_key
PAYMOB_INTEGRATION_ID=your_integration_id
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Email (AWS SES) ---
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
SES_FROM_EMAIL=noreply@yourdomain.com

# --- AI/ML Services ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# --- Monitoring ---
SENTRY_DSN=https://...@sentry.io/...
